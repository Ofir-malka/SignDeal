# Neon PostgreSQL — pooled connection (used by Prisma at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/signdeal?sslmode=require"

# Neon PostgreSQL — direct connection (used by Prisma for migrations only)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/signdeal?sslmode=require"

# ── Infobip SMS / WhatsApp ────────────────────────────────────────────────────
# Sign up at https://www.infobip.com — free trial available
# Your account base URL is shown in the Infobip portal (e.g. xxxxx.api.infobip.com)
INFOBIP_BASE_URL="https://XXXXX.api.infobip.com"
# API key — found under Settings → API Keys in the Infobip portal
INFOBIP_API_KEY=""
# SMS sender name or number shown to the recipient (subject to Infobip approval)
# Alphanumeric: max 11 chars, no spaces. Numeric: E.164 format e.g. +972501234567
INFOBIP_SMS_SENDER="SignDeal"

# ── App ───────────────────────────────────────────────────────────────────────
# Full base URL used server-side to build signing/payment links inside SMS and email.
# In production set this to your real domain, e.g. https://app.signdeal.co.il
APP_BASE_URL="http://localhost:3000"
# SMS test guard: when non-empty, real SMS is only sent to this phone number (E.164).
# Clear this value to disable all outbound SMS — safe default for new developers.
SMS_TEST_PHONE=""

# ── Auth.js ───────────────────────────────────────────────────────────────────
# 256-bit random secret — generate with: openssl rand -base64 32
# Required in all environments. Auth.js will throw on startup if missing.
AUTH_SECRET=""

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Both vars required to enable "המשך עם Google" buttons on login/register.
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add authorised redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ── Apple Sign In (optional) ──────────────────────────────────────────────────
# Both vars required to enable "המשך עם Apple" buttons on login/register.
# 1. Go to https://developer.apple.com/account/resources/identifiers
# 2. Create an App ID with Sign In with Apple capability
# 3. Create a Services ID (this is AUTH_APPLE_ID) with your domain + redirect URI:
#    https://YOUR_DOMAIN/api/auth/callback/apple
# 4. Create a Key with Sign In with Apple — download the .p8 file
# 5. AUTH_APPLE_SECRET = contents of the .p8 key file (include header/footer lines)
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=

# ── Brokerage payments — client pays broker (SEPARATE from HYP SaaS billing) ──
# Controls which provider handles client-to-broker brokerage fee collection.
# HYP billing (BILLING_PROVIDER) is completely separate and governs only the
# SaaS subscription fee brokers pay to SignDeal.
#
#   stub   — no network calls, deterministic test URLs (safe default for dev)
#   rapyd  — Rapyd hosted checkout (legacy; still supported for backwards compat)
#   stripe — Stripe Connect (Phase D+; requires broker onboarding via Phase B)
PAYMENT_PROVIDER="stub"

# Full base URL used to build client payment redirect URLs (success/cancel pages).
# Must exactly match what is registered in the payment provider's dashboard.
# In production: https://app.signdeal.co.il
# ⚠ Note: the code reads PAYMENT_REDIRECT_BASE_URL — include the _URL suffix.
PAYMENT_REDIRECT_BASE_URL="http://localhost:3000"

# ── Platform fee configuration (applies to all brokerage payment providers) ───
# These control how much SignDeal collects from each client payment.
# All default to 0 — set before going live to collect platform revenue.
#
#   FEE_MODE              BROKER = broker absorbs all fees
#                         CLIENT = client pays a convenience fee on top
#                         SPLIT  = fees split between broker and client (default)
#   PROVIDER_FEE_PERCENT  payment processor's cut, e.g. "1.7" for 1.7%
#   PLATFORM_FEE_PERCENT  SignDeal's cut, e.g. "0.5" for 0.5%
#                         For Stripe Connect, this becomes application_fee_amount.
FEE_MODE="SPLIT"
PROVIDER_FEE_PERCENT="0"
PLATFORM_FEE_PERCENT="0"

# ── Stripe Connect — client-to-broker brokerage payments (Phase B+) ───────────
# Required when PAYMENT_PROVIDER=stripe.
# ⚠ Do NOT use HYP / SaaS billing keys here — these are for broker payouts only.
#
# Dashboard: https://dashboard.stripe.com
# Test keys start with sk_test_ / pk_test_; live keys start with sk_live_ / pk_live_.
#
# STRIPE_SECRET_KEY                Server-side key — never expose to the browser.
#                                   Test:  sk_test_...
#                                   Live:  sk_live_...
# STRIPE_PUBLISHABLE_KEY            Client-side key — safe to expose (used in future
#                                   front-end Stripe.js Elements if needed).
#                                   Test:  pk_test_...
#                                   Live:  pk_live_...
# STRIPE_WEBHOOK_SECRET             Webhook signing secret for the CONNECT endpoint:
#                                   POST /api/stripe/connect/webhook
#                                   Handles account.updated events only.
#                                   Found in Dashboard → Webhooks → connect endpoint → Signing secret.
#                                   Format: whsec_...
#                                   Local dev: stripe listen --forward-to localhost:3000/api/stripe/connect/webhook
# STRIPE_PAYMENT_WEBHOOK_SECRET     Webhook signing secret for the PLATFORM PAYMENT endpoint:
#                                   POST /api/stripe/payment/webhook
#                                   Handles checkout.session.completed / expired,
#                                   payment_intent.payment_failed.
#                                   ⚠ Different endpoint, different secret from STRIPE_WEBHOOK_SECRET.
#                                   Found in Dashboard → Webhooks → payment endpoint → Signing secret.
#                                   Format: whsec_...
#                                   Local dev: stripe listen --forward-to localhost:3000/api/stripe/payment/webhook \
#                                     --events checkout.session.completed,checkout.session.expired,payment_intent.payment_failed
# STRIPE_CONNECT_CLIENT_ID          Platform's Connect client ID (ca_...) used if you choose
#                                   the OAuth onboarding flow instead of Account creation API.
#                                   Found in Dashboard → Connect → Settings.
#                                   Optional — only needed for OAuth-based onboarding (Phase B).
#
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PAYMENT_WEBHOOK_SECRET=
# STRIPE_CONNECT_CLIENT_ID=

# ── Billing — SaaS subscription (separate from brokerage payments) ────────────
# Controls which billing provider handles plan upgrades/downgrades.
# Separate from PAYMENT_PROVIDER (brokerage collection — see above).
#   stub  — no network calls, deterministic test URLs (safe default)
#   hyp   — HYP hosted checkout
BILLING_PROVIDER="stub"

# Required only when BILLING_PROVIDER=hyp (values from HYP / CreditGuard merchant portal):
# HYP_USER=                   # API username
# HYP_PASSWORD=               # API password (also used in response MAC verification)
# HYP_TERMINAL_NUMBER=        # 10-char terminal ID, e.g. "AB12345678"
# HYP_MID=                    # Merchant ID
# HYP_BASE_URL=               # Optional; defaults to UAT: https://cguat2.creditguard.co.il
#                             # Production: assigned by HYP (pattern: xxx.creditguard.co.il)

# ── SaaS recurring billing (Rail A — broker pays SignDeal) ────────────────────
# Drives the daily recurring-charge cron (/api/cron/billing/charge, 06:00 UTC). Every flag is
# read at runtime from process.env; in production set these in Vercel → Environment Variables
# (a value change requires a redeploy to take effect). This file is LOCAL ONLY and never deployed.
#
# Hard gate for REAL charges — applies to BOTH providers. Default off (no money moves).
ENABLE_REAL_RECURRING_CHARGES="false"
# Scan-only dry run: logs which subscriptions WOULD be charged; writes nothing, calls nothing.
BILLING_CHARGE_DRY_RUN="false"
# Execution mode after the gates pass: "stub" = full DB flow with NO provider network call;
# unset/other = real charge via the provider. ("stub" is the safe pre-money testing mode.)
RECURRING_BILLING_PROVIDER="stub"
# Grow recurring participation gate — SEPARATE from GROW_SAAS_ENABLED below. When off, the Grow
# subscription scan is skipped entirely (HYP, the temporary rollback provider, is unaffected).
ENABLE_GROW_RECURRING_CHARGES="false"

# ── Grow SaaS merchant (Rail A) — SignDeal's OWN merchant ─────────────────────
# ⚠ The Grow SaaS merchant apiKey is NOT an environment variable. It is stored as the encrypted
#   Platform secret GROW_SAAS_MERCHANT_API_KEY in the EncryptedSecret table (sealed; rail "A",
#   ownerType "Platform"), read only via the Rail A secret facade — never from .env.
GROW_SAAS_ENABLED="false"             # master switch for Rail A Grow checkout / token-setup
GROW_SAAS_ENVIRONMENT="sandbox"       # "sandbox" | "production" (host derived unless GROW_SAAS_HOST set)
GROW_SAAS_HOST=""                     # optional explicit host override, e.g. sandbox.meshulam.co.il
GROW_SAAS_USER_ID=""                  # SignDeal's Grow merchant userId
GROW_SAAS_PAGECODE=""                 # SignDeal's token-enabled pageCode

# ── Email (optional) ──────────────────────────────────────────────────────────
# Used for welcome emails. Without this key, sends are logged to console only.
# Sign up at https://resend.com — free tier available.
# AUTH_APPLE_SECRET=
# RESEND_API_KEY=
# EMAIL_FROM="SignDeal <noreply@signdeal.co.il>"
