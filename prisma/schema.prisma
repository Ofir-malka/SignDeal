// This is your Prisma schema file.
// Database connection is configured in prisma.config.ts (Prisma v6).

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Subscription enums ────────────────────────────────────────────────────────

enum BillingInterval {
  MONTHLY   // charged per calendar month
  YEARLY    // charged annually at a reduced rate
}

enum UserRole {
  BROKER   // default — every registered broker
  ADMIN    // SignDeal staff — grants access to /admin
}

enum PlanType {
  // ── Deprecated values — DO NOT write from app code ──────────────────────────
  // Kept in enum for Postgres referential integrity.
  // All rows migrated away in migration 002_billing_interval_and_new_plan_types.
  STARTER
  ENTERPRISE

  // ── Active values (Phase 1+) ─────────────────────────────────────────────────
  STANDARD    // 30 docs/month — ₪39/mo or ₪29/mo annually
  GROWTH      // 60 docs/month — ₪49/mo or ₪39/mo annually
  PRO         // 100 docs/month — ₪110/mo or ₪99/mo annually
  AGENCY      // Custom — null doc limit, contact sales
}

enum SubscriptionStatus {
  // ── Phase 2A: card-first trial flow ────────────────────────────────────────
  // Set at account creation. User must complete HYP checkout before any
  // dashboard access. Transitions to TRIALING once a card token is stored.
  // INCOMPLETE users are blocked identically to EXPIRED — no actions allowed.
  INCOMPLETE

  // ── Legacy / active statuses ────────────────────────────────────────────────
  TRIALING   // Card on file; 14-day trial active. No charges yet.
  ACTIVE     // Paid and current; recurring billing running.
  PAST_DUE   // Recurring charge failed; grace period before EXPIRED.
  CANCELED   // Canceled by user; access until currentPeriodEnd.
  EXPIRED    // Trial or subscription ended with no active payment method.
}

// ── User (broker) ──────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  fullName      String
  phone         String?
  licenseNumber String?   @unique  // nullable in DB; required at API/UI layer
  idNumber      String?            // nullable in DB; required at API/UI layer
  logoUrl       String?            // optional; upload not implemented yet

  // ── Auth.js fields ────────────────────────────────────────────────────────
  passwordHash      String?    // bcrypt hash; null for OAuth-only accounts
  emailVerified     DateTime?
  image             String?    // avatar URL from Google / Apple
  profileComplete   Boolean    @default(false) // true once phone+license+idNumber filled
  // Set to now() whenever the user successfully resets their password.
  // Any JWT issued before this timestamp is treated as stale and invalidated.
  // null = password has never been reset (no invalidation needed).
  passwordChangedAt DateTime?

  // ── SaaS role & plan ──────────────────────────────────────────────────────
  role            UserRole   @default(BROKER)

  createdAt  DateTime    @default(now())

  // ── Relations ─────────────────────────────────────────────────────────────
  contracts           Contract[]
  activities          Activity[]
  properties          Property[]
  messages            Message[]
  clients             Client[]
  subscription        Subscription?       // 1-to-1; created at registration
  billingCheckouts    BillingCheckout[]   // one row per checkout attempt
  contractUsageEvents ContractUsageEvent[] // immutable usage ledger (Phase 3E+)
  // Stripe Connect broker account (Phase A — client-to-broker brokerage payments).
  // Null until the broker completes Stripe Connect onboarding (Phase B).
  // Completely separate from HYP subscription billing.
  stripeAccount       BrokerStripeAccount?

  // ── Grow migration (Phase 1 foundation — additive; no runtime reads yet) ──
  growMerchant           GrowBrokerMerchant?     // Rail B — broker Grow merchant (1-to-1)
  growOnboardingSessions GrowOnboardingSession[] // Rail B — Grow onboarding attempts

  // ── Auth.js adapter relations ─────────────────────────────────────────────
  accounts   Account[]
  sessions   Session[]
}

// ── Client ─────────────────────────────────────────────────────────────────────
model Client {
  id        String     @id @default(cuid())
  userId    String                           // owning broker; required after backfill
  user      User       @relation(fields: [userId], references: [id])
  name      String
  phone     String
  email     String
  idNumber  String
  address   String?                          // residential address; completed by the client on the signing page
  createdAt DateTime   @default(now())
  contracts Contract[]
  messages  Message[]
}

// ── BrokerStripeAccount ────────────────────────────────────────────────────────
//
// One row per broker who has started or completed Stripe Connect onboarding.
// 1-to-1 with User; created when the broker first clicks "Connect with Stripe".
//
// ⚠ This is NOT related to HYP billing (SaaS subscription).
// HYP fields live on Subscription. These fields govern client-to-broker
// brokerage fee collection via Stripe Connect.
//
// Lifecycle:
//   Row absent       — broker has not started Stripe Connect onboarding
//   PENDING          — account created on Stripe; onboarding link sent
//   IN_PROGRESS      — broker opened the link but did not complete all steps
//   COMPLETE         — chargesEnabled + payoutsEnabled = true; ready for payments
//   RESTRICTED       — Stripe flagged or requires additional information
//
// chargesEnabled must be true before the payment-request route allows Stripe
// payment links to be created for a broker's contracts.

model BrokerStripeAccount {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Stripe-issued identifiers ──────────────────────────────────────────────
  // stripeAccountId is the Connect account ID (acct_...) returned by
  // stripe.accounts.create(). Unique across the platform — one acct_ per broker.
  stripeAccountId String @unique  // "acct_..."

  // ── Onboarding state ───────────────────────────────────────────────────────
  // Synced from Stripe account.capabilities / requirements via webhook or
  // GET /api/stripe/connect/status poll (Phase B).
  onboardingStatus StripeOnboardingStatus @default(PENDING)
  chargesEnabled   Boolean                @default(false)  // account.charges_enabled
  payoutsEnabled   Boolean                @default(false)  // account.payouts_enabled
  detailsSubmitted Boolean                @default(false)  // account.details_submitted

  // ── Account metadata ───────────────────────────────────────────────────────
  country  String @default("IL")   // ISO 3166-1 alpha-2 — all brokers are Israeli
  currency String @default("ils")  // ISO 4217 — Israeli Shekel

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Phase D: payout lifecycle events for this broker's Express account
  payoutEvents  StripePayoutEvent[]

  @@index([onboardingStatus])  // Phase B: "find all brokers pending onboarding"
}

// ── StripePayoutEvent ──────────────────────────────────────────────────────────
//
// One row per Stripe Payout (po_...) on a broker's Express account.
// Populated by the Connect webhook (payout.created → payout.paid/failed/canceled).
//
// ⚠ This is for CLIENT-TO-BROKER brokerage payouts ONLY.
//   HYP SaaS subscription billing is completely separate.
//
// Why a separate table:
//   A single payout batches many transfers (= many Payments).
//   Storing payout state on every Payment row would mean a single payout.failed
//   event requires updating N rows atomically — fragile and denormalized.
//   Instead: one StripePayoutEvent row per payout, Payment.payoutId FK links them.
//
// Lifecycle:
//   payout.created   → status="pending"
//   payout.paid      → status="paid", arrivalDate set
//                      + reconciliation: Payment.payoutId → this row's payoutId
//   payout.failed    → status="failed", failureCode + failureMessage set
//   payout.canceled  → status="canceled"
//
// status values match Stripe's payout.status strings exactly:
//   "pending" | "in_transit" | "paid" | "failed" | "canceled"

model StripePayoutEvent {
  id     String @id @default(cuid())

  // Which broker's Express account generated this payout.
  // FK to BrokerStripeAccount.stripeAccountId (the acct_... Connect account ID).
  stripeAccountId String
  brokerAccount   BrokerStripeAccount @relation(fields: [stripeAccountId], references: [stripeAccountId], onDelete: Cascade)

  // Stripe's payout identifier — unique across the platform.
  payoutId  String @unique  // "po_..."

  // ── Lifecycle ────────────────────────────────────────────────────────────────
  status    String   // "pending" | "in_transit" | "paid" | "failed" | "canceled"

  // ── Amount ───────────────────────────────────────────────────────────────────
  amount    Int      // total payout amount in agorot (Stripe sends smallest currency unit)
  currency  String   @default("ils")

  // ── Settlement ────────────────────────────────────────────────────────────────
  // Populated when status → "paid".  Stripe arrival_date is a Unix timestamp;
  // the webhook handler converts: new Date(payout.arrival_date * 1000).
  arrivalDate DateTime?

  // ── Failure details ───────────────────────────────────────────────────────────
  // Populated when status → "failed".  Both null for non-failed payouts.
  failureCode    String?  // Stripe failure_code, e.g. "account_closed", "invalid_account_number"
  failureMessage String?  // Human-readable failure reason from Stripe

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Payments reconciled into this payout (via balance transaction reconciliation
  // on payout.paid).  Null until reconciliation links them.
  payments  Payment[]

  @@index([stripeAccountId])   // fast "all payouts for this broker"
  @@index([status])            // "all failed payouts", "all pending payouts"
  @@index([arrivalDate])       // chronological + upcoming-payout queries
}

// ── ContractTemplate ───────────────────────────────────────────────────────────

enum ContractTemplateKey {
  INTERESTED_BUYER          // החתמת מתעניין
  OWNER_EXCLUSIVE           // החתמת בעל נכס / בלעדיות
  BROKER_COOP               // הסכם שיתוף פעולה בין מתווכים
  INTERESTED_BUYER_RENTAL   // החתמת מתעניין — שכירות (resolved when dealType = RENTAL)
  INTERESTED_BUYER_SALE     // החתמת מתעניין — מכירה (resolved when dealType = SALE)
  INTERESTED_BUYER_BOTH     // החתמת מתעניין — מכירה והשכרה (resolved when dealType = BOTH)
  OWNER_EXCLUSIVE_RENTAL    // החתמת בעל נכס — בלעדיות להשכרה (resolved when dealType = RENTAL)
  OWNER_EXCLUSIVE_SALE      // החתמת בעל נכס — בלעדיות למכירה (resolved when dealType = SALE)
}

// How the rental brokerage fee was chosen by the broker. Drives the dynamic
// wording of clause 6.1 in the INTERESTED_BUYER_RENTAL template. Null for
// SALE/BOTH and for every legacy contract.
enum RentalCommissionMode {
  ONE_MONTH   // חודש שכירות אחד
  FIXED       // סכום קבוע
  MONTHS      // מספר חודשי שכירות (1–12) — rentalCommissionMonths holds the count (owner-exclusive rental)
}

// How the sale brokerage fee was chosen by the broker. Drives the dynamic
// wording of clause 5.1 in the INTERESTED_BUYER_SALE template. Null for
// non-sale flows and for every legacy contract.
enum SaleCommissionMode {
  PERCENT   // אחוז ממחיר העסקה
  FIXED     // סכום קבוע
}

enum ContractTemplateLanguage {
  HE   // עברית   — default; required for every templateKey
  EN   // English
  FR   // Français
  RU   // Русский
  AR   // العربية
}

model ContractTemplate {
  id          String                   @id @default(cuid())
  title       String
  templateKey ContractTemplateKey?              // null = unassigned; set to auto-match by contract type
  language    ContractTemplateLanguage @default(HE)  // resolved together with templateKey
  content     String                   @db.Text // legal text with {{placeholder}} syntax
  isActive    Boolean                  @default(true)
  version     Int                      @default(1)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  contracts Contract[]
}

// ── Contract ───────────────────────────────────────────────────────────────────
model Contract {
  id              String          @id @default(cuid())
  contractType    String
  dealType        DealType
  status          SignatureStatus @default(DRAFT)

  // Property
  propertyAddress String
  propertyCity    String
  propertyPrice   Int             // stored in agorot (smallest currency unit; monthly rent for RENTAL/BOTH, sale price for SALE)
  propertySalePrice Int?          // agorot; sale asking price — set only for dealType BOTH (propertyPrice = monthly rent there)
  commission      Int             // stored in agorot (rental commission for BOTH; full commission for SALE/RENTAL)
  commissionSale  Int?            // stored in agorot; only set when dealType = BOTH (sale-side commission)
  rentalCommissionMode RentalCommissionMode? // null for SALE/BOTH & legacy; drives rental clause 6.1 wording
  rentalCommissionMonths Int?                // 1–12; set only when rentalCommissionMode = MONTHS (owner-exclusive rental)
  saleCommissionMode    SaleCommissionMode?  // null for non-sale-template & legacy; drives sale clause 5.1 wording
  saleCommissionPercent Float?               // human percent (2, 1.5); set only when saleCommissionMode = PERCENT

  // Exclusivity period (owner-exclusive templates only; null elsewhere).
  // End date follows the inclusive day-before convention in the UI
  // (3 months from 01.08 -> 31.10). Rendered via {{exclusivityStartDate}} /
  // {{exclusivityEndDate}} in the frozen generatedText.
  exclusivityStartsAt DateTime?
  exclusivityEndsAt   DateTime?

  // Dates
  createdAt       DateTime        @default(now())
  sentAt          DateTime?
  signedAt        DateTime?
  dealClosedAt    DateTime?

  // Deal state
  dealClosed                Boolean @default(false)
  hideFullAddressFromClient Boolean @default(false)

  // Signing audit (used in public /contracts/sign/[token] URL)
  signatureToken   String?         @unique
  signatureIp      String?
  signatureData    String?         // base64 PNG of drawn signature
  signatureHash    String?         // SHA-256(signatureData) — client-supplied; kept for backward compat
  signatureDigest  String?         // server-computed SHA-256 over full signing context (see lib/signature-integrity.ts)
  userAgent        String?         // browser/device string at signing time

  // Template snapshot (frozen at creation time; immutable after that)
  language        String          @default("HE")   // "HE"|"EN"|"FR"|"RU"|"AR" — language used at creation
  templateId      String?
  template        ContractTemplate? @relation(fields: [templateId], references: [id])
  generatedText   String?         @db.Text

  // Relations
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id])
  propertyId      String?
  property        Property?       @relation(fields: [propertyId], references: [id])
  activities      Activity[]
  payment         Payment?
  messages        Message[]
  usageEvent      ContractUsageEvent? // one immutable usage slot; survives contract deletion
}

// ── Payment ────────────────────────────────────────────────────────────────────
model Payment {
  id                String        @id @default(cuid())
  contractId        String        @unique
  contract          Contract      @relation(fields: [contractId], references: [id])
  status            PaymentStatus @default(PENDING)
  amount            Int           // stored in agorot
  provider          String?       // "cardcom" | "meshulam" | "tranzila"
  providerPaymentId String?       // external ID filled by webhook in Phase 2
  paymentUrl        String?       // hosted payment page URL sent to client
  paidAt            DateTime?

  // ── Fee breakdown (computed at payment-request creation time) ──────────────
  grossAmount   Int?       // total charged to customer, in agorot
  processorFee  Int?       // payment-processor cut, in agorot
  platformFee   Int?       // SignDeal platform cut, in agorot
  netAmount     Int?       // broker net after fees, in agorot
  feePaidBy     FeePaidBy? // BROKER | CLIENT | SPLIT — who absorbs which fees

  // ── Fee config snapshot (stored at creation for auditability) ──────────────
  providerFeePercent Float @default(0)  // e.g. 1.7 = 1.7%; used to compute processorFee
  platformFeePercent Float @default(0)  // e.g. 0.5 = 0.5%; used to compute platformFee
  // feeMode is persisted via feePaidBy (BROKER | CLIENT | SPLIT)

  // ── Stripe Connect fields (Phase A — null for Rapyd payments) ─────────────
  // providerPaymentId doubles as the Stripe PaymentIntent ID (pi_...) when
  // provider = "stripe". These fields are only populated for Stripe payments.
  //
  // stripeTransferId      — set when Stripe fires the transfer.created webhook,
  //                         confirming the broker's Connected Account was funded.
  //                         Format: "tr_..."
  // applicationFeeAmount  — the actual platform fee collected by Stripe in agorot
  //                         (= Stripe's application_fee_amount).  May differ from
  //                         the computed platformFee if rounding or Stripe caps apply.
  stripeTransferId     String?  // "tr_..." — null until transfer confirmed
  applicationFeeAmount Int?     // agorot; null for Rapyd or pre-Phase-D payments

  // ── Stripe Checkout Session fields (Phase C — null for Rapyd payments) ────
  // stripeCheckoutSessionId — set when the Stripe Checkout Session is created.
  //   Used to: look up the Payment in webhook events, check for open sessions
  //   (idempotency), and match the session_id query param on /pay/complete.
  //   Format: "cs_..."
  // stripePaymentIntentId   — set when checkout.session.completed webhook fires.
  //   Used to: reconcile transfers, reference charges, future refund flow.
  //   Format: "pi_..."
  stripeCheckoutSessionId  String?  // "cs_..." — null until Checkout Session created
  stripePaymentIntentId    String?  // "pi_..." — null until checkout.session.completed

  // ── Stripe Transfer + Payout tracking (Phase D — null for Rapyd payments) ──
  // transferStatus — lifecycle of the Stripe Transfer (tr_...) that funds the broker.
  //   "paid"     — transfer landed in the broker's Stripe Express balance.
  //   "reversed" — transfer was reversed (Phase E handles accounting/refund).
  //   null       — Rapyd payment, or Stripe payment before transfer.created fires.
  //
  // payoutId — FK to StripePayoutEvent.payoutId.  Populated on payout.paid when
  //   we reconcile Stripe balance transactions to find which Payment was swept
  //   into that payout.  Null until reconciliation runs.
  transferStatus  String?             // "paid" | "reversed"
  payoutId        String?             // "po_..." — null until reconciled
  payoutEvent     StripePayoutEvent?  @relation(fields: [payoutId], references: [payoutId], onDelete: SetNull)

  // ── Refund fields (Phase E — null for non-refunded payments) ──────────────
  // Populated by the charge.refunded webhook handler.
  //
  // refundedAt    — wall-clock time the refund was processed (from Stripe event).
  // refundAmount  — amount refunded in agorot.  For full refunds this equals
  //                 grossAmount.  Stored even for full refunds so queries don't
  //                 need to join on the charge.
  // stripeRefundId — Stripe's Refund object ID ("re_...").  Null when the
  //                  webhook fires before refund expansion is available.
  // refundReason  — Stripe refund reason string: "duplicate" | "fraudulent" |
  //                 "requested_by_customer" | null (when not set by the operator).
  refundedAt     DateTime?  // null until charge.refunded fires
  refundAmount   Int?       // agorot — null until refunded
  stripeRefundId String?    // "re_..." — null when not yet available
  refundReason   String?    // Stripe reason string or null

  // ── Grow / Rail B routing (Phase 1 foundation — additive; no runtime reads yet) ──
  // routedProvider records which Rail B processor handled this payment.
  // Kept separate from `provider` (the legacy/HYP discriminator) to avoid overloading it.
  routedProvider       String?        // "grow" | "stripe"
  paymentMethod        PaymentMethod? // APPLE_PAY | GOOGLE_PAY | BIT | CREDIT_CARD | BANK_TRANSFER
  growProcessId        String?        // Grow createPaymentProcess id (populated in later phases)
  growTransactionId    String?        // Grow transaction id (populated in later phases)
  cardLast4            String?        // masked only — never the full PAN

  // ── Grow Rail B — Step 1 (createPaymentProcess) + Step 2 (payment webhook) ──
  growProcessToken     String?            // Grow process token — stored at create (Step 1)
  growTransactionToken String?            // Grow transaction token — set by the payment webhook (Step 2)
  growAsmachta         String?            // Grow approval (asmachta) code — set by the webhook (Step 2)
  growRaw              String?  @db.Text  // raw verified Grow response snapshot — audit (Step 2)

  // Bank transfer — SETTLEMENT TRACKING ONLY (non-PII). Transient-first policy:
  // payer bank details are NOT persisted by default (forwarded to Grow in-request,
  // then discarded). The masked/encrypted payer columns (payerBankAccountLast4,
  // payerBankCode, payerBankBranchCode, payerBankSecretRef) are DEFERRED — added
  // only if Grow confirms it requires them for reconciliation.
  settlementStatus     String?        // "PENDING" | "SETTLED" | "FAILED"
  settlementExpectedAt DateTime?

  createdAt         DateTime      @default(now())
  messages          Message[]

  @@index([stripeCheckoutSessionId])  // Phase C: fast webhook + idempotency lookup
  @@index([payoutId])                 // Phase D: payout → payments reconciliation
  @@index([growTransactionId])        // Phase 1: Grow transaction lookup (empty until later phases)
}

// ── Activity log ───────────────────────────────────────────────────────────────
model Activity {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  message    String
  createdAt  DateTime @default(now())
}

// ── Enums ──────────────────────────────────────────────────────────────────────
enum SignatureStatus {
  DRAFT           // טיוטה — created, not yet sent
  SENT            // נשלח — signing link delivered to client
  OPENED          // נפתח — client opened the signing link
  SIGNED          // נחתם — client signed; no payment expected
  PAYMENT_PENDING // ממתין לתשלום — signed; broker sent a payment request
  PAID            // שולם — payment confirmed by provider webhook
  EXPIRED         // פג תוקף — link expired without signature
  CANCELED        // בוטל
}

enum DealType {
  RENTAL    // שכירות
  SALE      // מכירה
  BOTH      // גם וגם — rental + sale commissions stored separately
}

enum PaymentStatus {
  PENDING   // ממתין לתשלום
  PAID      // שולם
  FAILED    // נכשל
  CANCELED  // בוטל
  REFUNDED  // הוחזר — Stripe charge.refunded webhook processed
}

enum FeePaidBy {
  BROKER           // מתווך נושא בעלויות
  CLIENT           // לקוח משלם עמלת נוחות
  SPLIT            // חלוקה מותאמת אישית
  BREAK_EVEN_SPLIT // עלויות Stripe מחולקות 50/50 בין לקוח למתווך; SignDeal ללא רווח
}

// ── Stripe Connect enums ───────────────────────────────────────────────────────
// Separate from HYP billing enums — these govern client-to-broker payments only.

enum StripeOnboardingStatus {
  PENDING      // account created on Stripe; onboarding link not yet completed
  IN_PROGRESS  // broker opened the onboarding link but did not finish
  COMPLETE     // chargesEnabled + payoutsEnabled = true; ready to receive payments
  RESTRICTED   // Stripe flagged the account or requires additional verification
}

enum WebhookEventStatus {
  RECEIVED   // event stored; processing in progress
  PROCESSED  // event handled successfully; no further action needed
  IGNORED    // duplicate or event type not handled; idempotency guard triggered
  FAILED     // processing threw an error; see error column for details
}

enum PropertyType {
  APARTMENT  // דירה
  HOUSE      // בית פרטי
  OFFICE     // משרד
  LAND       // קרקע
  PARKING    // חניה
  OTHER      // אחר
}

enum PropertyListingType {
  RENTAL  // להשכרה
  SALE    // למכירה
  BOTH    // גם וגם
}

model Property {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id])

  address     String
  city        String
  type        PropertyType        @default(APARTMENT)
  listingType PropertyListingType @default(RENTAL)
  rooms       Float?              // 3, 3.5, 4 …
  floor       Int?
  sizeSqm     Float?       // square metres
  askingPrice Int?         // agorot — optional starting price

  contracts   Contract[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Auth.js adapter models ─────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Messaging enums ────────────────────────────────────────────────────────────

enum MessageChannel {
  SMS
  WHATSAPP
  EMAIL
}

enum MessageStatus {
  PENDING    // נוצר, טרם נשלח
  SENT       // נשלח לספק, ממתין לאישור מסירה
  DELIVERED  // אושרה מסירה על ידי הספק
  FAILED     // נכשל לאחר כל ניסיונות השליחה
  CANCELED   // בוטל לפני השליחה
}

enum MessageType {
  CONTRACT_SIGNING_LINK    // שליחת קישור חתימה ללקוח
  PAYMENT_REQUEST_LINK     // שליחת קישור תשלום ללקוח
  SIGNING_REMINDER         // תזכורת לחתימה ללקוח
  PAYMENT_REMINDER         // תזכורת לתשלום ללקוח
  BROKER_CONTRACT_SIGNED      // התראה למתווך: לקוח חתם
  BROKER_PAYMENT_RECEIVED     // התראה למתווך: תשלום התקבל
  USER_WELCOME                // אימייל ברוכים הבאים לאחר הרשמה
  USER_PASSWORD_RESET         // אימייל איפוס סיסמה
  CLIENT_CONTRACT_SIGNED_PDF  // אימייל ללקוח: החוזה החתום + PDF מצורף
  SUBSCRIPTION_PAYMENT_FAILED // התראה למתווך: תשלום מנוי נכשל
  TRIAL_EXPIRED               // התראה למתווך: תקופת הניסיון הסתיימה ללא אמצעי תשלום
  SUBSCRIPTION_SUSPENDED      // התראה למתווך: המנוי הושהה לאחר כישלונות חיוב מרובים
}

// ── MessageTemplate ────────────────────────────────────────────────────────────
model MessageTemplate {
  id        String         @id @default(cuid())
  type      MessageType
  channel   MessageChannel
  nameHe    String         // Hebrew label for UI, e.g. "קישור חתימה — WhatsApp"
  subject   String?        // email subject line; null for SMS / WhatsApp
  body      String         // template body with {{placeholders}}
                           // e.g. "שלום {{clientName}}, לחץ לחתימה: {{signingUrl}}"
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  messages  Message[]

  @@unique([type, channel]) // one active template per type+channel combination
}

// ── Message (send log + delivery tracking) ─────────────────────────────────────
model Message {
  id String @id @default(cuid())

  // Who triggered the send (null = system-triggered, e.g. post-signing broker alert)
  userId         String?
  user           User?            @relation(fields: [userId], references: [id])

  // Recipient — denormalized so the record survives if client is later deleted
  clientId       String?
  client         Client?          @relation(fields: [clientId], references: [id])
  recipientPhone String?
  recipientEmail String?

  // Context — what triggered this message
  contractId     String?
  contract       Contract?        @relation(fields: [contractId], references: [id])
  paymentId      String?
  payment        Payment?         @relation(fields: [paymentId], references: [id])

  // Content
  type           MessageType
  channel        MessageChannel
  templateId     String?
  template       MessageTemplate? @relation(fields: [templateId], references: [id])
  body           String           // fully-rendered body after placeholder substitution
  subject        String?          // email subject (null for SMS / WhatsApp)

  // Provider tracking
  provider          String        // "infobip" | "resend" | "twilio"
  providerMessageId String?       // provider's own message ID — used to match webhooks
  providerResponse  String?       // raw JSON response from provider (for debugging)

  // Delivery status + retry
  status        MessageStatus @default(PENDING)
  attempts      Int           @default(0)   // number of send attempts so far
  lastAttemptAt DateTime?
  nextRetryAt   DateTime?     // non-null when scheduled for automatic retry
  deliveredAt   DateTime?
  failureReason String?       // provider error string on FAILED status

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])     // Phase E: watchdog + admin queries for PENDING/FAILED messages
  @@index([createdAt])  // Phase E: time-based watchdog queries ("PENDING older than 1h")
}

// ── Subscription ───────────────────────────────────────────────────────────────
//
// One row per User — always exists once a user registers.
//
// Phase 1  — schema + plan limit enforcement at API layer.
// Phase 2A — INCOMPLETE status + card-token fields added (this migration).
//            Checkout flow still activates TRIALING immediately; recurring
//            charge fields are placeholders for Phase 2B.
// Phase 2B — /billing/success bifurcation: INCOMPLETE → TRIALING with card;
//            TRIALING/ACTIVE → ACTIVE for paid upgrades.
// Phase 3  — Recurring billing engine reads growSaasChargeSecretRef + nextBillingAt
//            to charge via Grow. billingFailures drives retry/suspend logic.

model Subscription {
  id     String @id @default(cuid())
  userId String @unique                    // 1-to-1; cascade-delete with user
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Plan & status ──────────────────────────────────────────────────────────
  plan   PlanType           @default(STANDARD)
  status SubscriptionStatus @default(INCOMPLETE)
  //   ^^^^ Changed from TRIALING to INCOMPLETE in Phase 2A.
  //   New accounts start INCOMPLETE until a card token is stored.
  //   Existing TRIALING rows keep their status (no backfill needed).

  // ── Trial ──────────────────────────────────────────────────────────────────
  // Null when INCOMPLETE — trial clock starts only after card approval.
  // Set to activatedAt + TRIAL_DAYS during the INCOMPLETE → TRIALING transition.
  trialEndsAt DateTime?

  // ── Billing interval ───────────────────────────────────────────────────────
  // Selected by the user during onboarding checkout (or /settings/billing).
  // Default MONTHLY is correct for all existing TRIALING rows.
  billingInterval BillingInterval @default(MONTHLY)

  // ── Billing provider ───────────────────────────────────────────────────────
  billingProvider       String?  // "hyp" | "grow" | future provider slug

  // ── Grow SaaS billing (Rail A — Phase 1 foundation; additive, no runtime reads yet) ──
  growSaasCustomerId      String?  // Grow SaaS customer identifier (populated in later phases)
  growSaasChargeSecretRef String?  // handle → EncryptedSecret (purpose = GROW_SAAS_CHARGE_TOKEN)

  // ── Card-on-file ──────────────────────────────────────────────────────────
  //
  // Card metadata captured when a card is stored (Grow token-setup / card-update;
  // legacy HYP rows also populated these). The recurring engine charges via the
  // Grow sealed token (growSaasChargeSecretRef); `billingFailures` drives the
  // retry / suspend / cancel logic, and `nextBillingAt` is the cron cursor —
  // charge all rows where nextBillingAt <= now() and status IN (TRIALING, ACTIVE).
  //
  chargeToken  String?    // 19-digit token from action=getToken — used for Phase 3B action=soft charges.
                          // Treat as sensitive: never log, never expose to client.
  cardBrand    String?    // e.g. "VISA", "MASTERCARD" — populated if provider returns it.
  cardLast4    String?    // Last 4 digits extracted from HYP cardMask (e.g. "1111").
  cardExpMonth Int?       // Card expiry month 1-12.
  cardExpYear  Int?       // Card expiry year (4-digit, e.g. 2028).

  // ── Card lifecycle timestamps ───────────────────────────────────────────────
  tokenCreatedAt DateTime?  // When the card token was first stored (INCOMPLETE → TRIALING).

  // ── Recurring billing state (Phase 3 — populated by billing engine) ────────
  // ▶ Phase 3 CONNECT POINT: billing cron populates these after every charge.
  firstPaymentAt  DateTime?  // Timestamp of the first successful recurring charge.
                             // Null during trial. Set when TRIALING → ACTIVE.
  nextBillingAt   DateTime?  // When the next charge is due. Billing cron queries this.
                             // Set to trialEndsAt on card storage; updated after each charge.
  billingFailures Int        @default(0)
                             // Count of consecutive failed recurring charges.
                             // Incremented by billing engine on each failure.
                             // Reset to 0 on success.
                             // ▶ Phase 3: after N failures → status = PAST_DUE → EXPIRED.

  // ── Current billing period (filled after first paid charge) ───────────────
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  // ── Lifecycle timestamps ───────────────────────────────────────────────────
  canceledAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  events  SubscriptionEvent[]
  charges BillingCharge[]      // Phase 3B: one row per charge attempt

  @@index([status])                    // fast queries: "all TRIALING users", "all INCOMPLETE users"
  @@index([trialEndsAt])               // fast queries: "trials expiring soon"
  @@index([nextBillingAt])             // Phase 3: billing cron cursor — "charge due now"
  @@index([status, nextBillingAt])     // Phase E: compound index for billing cron WHERE status IN (...) AND nextBillingAt <= now
  @@index([billingProvider])           // Phase 1: provider-scoped queries (empty until Grow rollout)
}

// ── SubscriptionEvent ──────────────────────────────────────────────────────────
//
// Append-only audit log. Never update or delete rows.
// Required for billing dispute resolution and admin debugging.

model SubscriptionEvent {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // ── What changed ──────────────────────────────────────────────────────────
  event      String              // "trial_started" | "upgraded" | "downgraded"
                                 // | "canceled" | "reactivated" | "expired"
                                 // | "payment_succeeded" | "payment_failed"
                                 // | "admin_override"
  fromPlan   PlanType?
  toPlan     PlanType?
  fromStatus SubscriptionStatus?
  toStatus   SubscriptionStatus?

  // ── Who/what triggered the change ─────────────────────────────────────────
  source   String  // "registration" | "admin" | "webhook" | "user" | "system"
  actorId  String? // userId of admin who made the change; null for system/webhook

  // ── Raw context (webhook payload, admin note, etc.) ───────────────────────
  metadata String? @db.Text // JSON string — keep raw for debugging

  createdAt DateTime @default(now())

  @@index([subscriptionId])   // look up all events for a subscription
  @@index([createdAt])        // chronological queries
}

// ── PasswordResetToken ────────────────────────────────────────────────────────
//
// One row per in-flight password-reset request.
// Security properties:
//   • `token` stores SHA-256(rawToken) — the raw token is only ever in the URL.
//   • `expires` is set to now() + 1 hour; checked before accepting the reset.
//   • At most one active token per email — old tokens are deleted before insert.
//   • Token is hard-deleted atomically with the password update ($transaction).
//
// Not a FK on userId so the flow works even for edge-case account states.

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String                        // user email; not a FK — no cascade risk
  token     String   @unique              // SHA-256(rawToken) hex — never stored raw
  expires   DateTime                      // now() + 1 hour at creation time
  createdAt DateTime @default(now())

  @@index([email])
}

// ── BillingCheckout ────────────────────────────────────────────────────────────
//
// One row per checkout attempt. Created when the user is redirected to HYP,
// resolved (SUCCEEDED / FAILED) when HYP calls back to /billing/success.
//
// Serves three purposes:
//   1. Replay protection — callback uniqueID must match a real issued Order.
//   2. Context carrier  — stores plan + interval so the success page knows what to activate.
//   3. Idempotency      — SUCCEEDED guard prevents double-activation on page reload.

enum BillingCheckoutStatus {
  PENDING    // checkout initiated; user sent to HYP — awaiting callback
  SUCCEEDED  // HYP returned success, MAC verified, subscription activated
  FAILED     // HYP returned failure, or MAC verification failed
  EXPIRED    // no callback received within 30 minutes of creation
}

model BillingCheckout {
  id       String                @id @default(cuid())
  userId   String
  user     User                  @relation(fields: [userId], references: [id])
  order    String                @unique  // "sd-<uuid>" — the Order param sent to HYP
  plan     PlanType
  interval BillingInterval
  status   BillingCheckoutStatus @default(PENDING)

  // ── Checkout purpose (Phase 4B) ────────────────────────────────────────────
  // Disambiguates the activation path in /billing/success so we don't have to
  // infer intent from subscription state (which is ambiguous for PMU vs upgrade).
  //
  // "checkout"              — normal new subscription or upgrade (default; backward-compat)
  // "recovery"              — PAST_DUE / billing-warning user re-entering card;
  //                          activateCheckout resets billingFailures, sets ACTIVE
  // "payment_method_update" — healthy subscriber updating card; activateCheckout
  //                          updates card fields only, no billing-state changes
  purpose  String  @default("checkout")

  // ── Grow card mask (set when the Grow token-setup checkout is claimed) ──────
  cardMask   String?  // safe to store plain, e.g. "4111****1111"

  // ── Grow Rail A token-setup (Phase 1) ──────────────────────────────────────
  growProcessId    String?  // createPaymentProcess processId — for getPaymentProcessInfo verify
  growProcessToken String?  // createPaymentProcess processToken — paired handle

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt  DateTime  @default(now())
  expiresAt  DateTime              // createdAt + 30 min; HYP hosted-page sessions expire
  resolvedAt DateTime?             // set when status moves to SUCCEEDED / FAILED

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

// ── BillingCharge ──────────────────────────────────────────────────────────────
//
// One row per charge attempt against a Subscription.
// Written by the recurring billing cron (Phase 3B+).
//
// Lifecycle:
//   PENDING    → created when a charge is initiated (Phase 3C will add this)
//   SUCCEEDED  → HYP action=soft returned CCode=0; money collected
//   FAILED     → HYP action=soft returned non-zero CCode; retry logic applies
//   SKIPPED    → subscription not eligible at run time (already charged, expired, etc.)
//
// The cron keeps Subscription.billingFailures and Subscription.nextBillingAt
// in sync after each attempt. BillingCharge rows are append-only audit records.

enum BillingChargeStatus {
  PENDING    // charge initiated — in flight (Phase 3C)
  SUCCEEDED  // HYP CCode=0 — money collected
  FAILED     // HYP non-zero CCode — retry logic applies
  SKIPPED    // not eligible at charge time; no HYP call made
}

model BillingCharge {
  id             String              @id @default(cuid())
  subscriptionId String
  subscription   Subscription        @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  userId         String              // denormalised for fast queries without a join

  status         BillingChargeStatus @default(PENDING)

  // ── Amount + plan snapshot ─────────────────────────────────────────────────
  // Captured at charge time so the record is self-contained even if the
  // subscription is later upgraded, downgraded, or cancelled.
  amountAgorot   Int                 // amount in agorot (100 agorot = ₪1)
  plan           PlanType            // plan at time of charge
  interval       BillingInterval     // billing interval at time of charge

  // ── Billing period this charge covers ──────────────────────────────────────
  periodStart    DateTime            // currentPeriodEnd before this charge
  periodEnd      DateTime            // new currentPeriodEnd after a successful charge

  // ── HYP response fields (legacy — historical rows only; no longer written) ──
  hypCCode       String?             // raw CCode returned by HYP (0 = success) — historical
  hypAuthCode    String?             // HYP authorization code (ACode) — historical

  // ── Grow response fields (Rail A — Phase 1 foundation; additive, no runtime reads yet) ──
  growTransId      String?            // Grow transaction id (populated in later phases)
  growStatusCode   String?            // Grow status/result code (populated in later phases)
  growApprovalCode String?            // Grow approval code (populated in later phases)
  growRaw          String? @db.Text   // intentionally never populated — raw provider response may contain card-adjacent values

  // ── Retry state ────────────────────────────────────────────────────────────
  attemptNumber  Int       @default(1)  // 1 = first attempt; incremented on each retry
  nextRetryAt    DateTime?              // when to retry; null = no retry scheduled

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([subscriptionId, periodStart])  // Phase E: DB-level idempotency — one charge row per subscription per billing period start
  @@index([subscriptionId])  // look up all charges for a subscription
  @@index([userId])          // look up all charges for a user
  @@index([status])          // "all FAILED charges", "all PENDING charges"
  @@index([createdAt])       // chronological queries + billing reports
}

// ── ContractUsageEvent ─────────────────────────────────────────────────────────
//
// Immutable usage ledger — one row per contract created.
//
// Problem solved: getMonthlyDocumentUsage() previously counted live Contract rows.
// Deleting a contract reduced the count, letting users bypass monthly limits.
// This table is the authoritative usage source — deletion-immune by design.
//
// Key properties:
//   • Written atomically in the same $transaction as the Contract row.
//   • contractId uses onDelete: SetNull — hard-deleting a contract nulls the FK
//     but keeps this row; the monthly count is unaffected.
//   • @unique on contractId prevents duplicate events per live contract.
//     In Postgres, NULL ≠ NULL so multiple rows with contractId = null are legal.
//   • userId uses onDelete: Cascade — if a user is deleted, their events go too.
//   • plan is a plain String snapshot (not a PlanType enum FK) so plan renames
//     or deprecated values never break historical records.
//   • Never updated or deleted by application code (append-only).

model ContractUsageEvent {
  id         String    @id @default(cuid())

  // Owner of this usage slot.
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Which contract consumed this slot.
  // Nullable: SET NULL when the contract is hard-deleted (FK onDelete: SetNull).
  // @unique: enforces one event per live contract; nulls are exempt in Postgres.
  contractId String?   @unique
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  // Plan active at creation — audit snapshot for analytics.
  // e.g. "STANDARD" | "GROWTH" | "PRO" | "AGENCY"
  plan       String

  // Billing window key — which calendar month this slot belongs to.
  // Mirrors Contract.createdAt; written once at creation; never updated.
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])  // getMonthlyDocumentUsage: count per user per month
  @@index([contractId])         // FK traversal index
}

// ── AuditLog ───────────────────────────────────────────────────────────────────
//
// Append-only cross-cutting audit trail for critical user and system actions.
//
// Design decisions:
//   • No FK on userId — audit rows must survive user deletion.
//   • No FK on entityId — a single int FK cannot span contracts, payments,
//     subscriptions, and users simultaneously; cascades would destroy the trail.
//   • metadata is Json (JSONB) — structured and queryable; never holds secrets,
//     full phone/email, card tokens, or idNumbers (enforced in the helper).
//   • No updatedAt — rows are written once and never modified.
//   • ip / userAgent are nullable — omitted for cron and system-to-system events.
//
// Action catalogue (string, not enum — avoids migration churn for new actions):
//   contract.created                   contract.signed
//   contract.payment_request.created   contract.payment.paid
//   contract.integrity.failed
//   subscription.activated             subscription.canceled
//   subscription.payment.succeeded     subscription.payment.failed
//   admin.user.role_changed
//   admin.template.created             admin.template.updated
//   admin.template.deleted
//
// Retention: no automated cleanup at launch. Revisit at 500 K rows.

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?                        // null = system / webhook / public-endpoint action
  action     String                         // see action catalogue above
  entityType String                         // "contract" | "payment" | "user" | "subscription" | "contractTemplate"
  entityId   String?                        // affected row id; null for collection-level actions
  metadata   Json?                          // structured context — sanitized before write; NEVER raw PII/secrets
  ip         String?                        // request IP; null for cron/server-to-server events
  userAgent  String?                        // browser UA; null for server-to-server events
  createdAt  DateTime @default(now())

  // ── Indexes ──────────────────────────────────────────────────────────────────
  @@index([userId, createdAt])      // "all actions by this broker" (chronological)
  @@index([entityType, entityId])   // "all audit events for contract X"
  @@index([action])                 // "all contract.signed events"
  @@index([createdAt])              // chronological queries + future retention cleanup
}

// ── WebhookEvent ───────────────────────────────────────────────────────────────
//
// Append-only log of inbound webhook events from payment providers.
// Serves as the authoritative idempotency store for all webhook processing.
//
// ⚠ This is for CLIENT-TO-BROKER payment webhooks (Stripe, Rapyd).
// HYP billing webhooks (SaaS subscription) are NOT stored here — HYP
// uses the BillingCheckout.status and BillingCharge rows for idempotency.
//
// Idempotency key: (provider, eventId) — a composite unique index.
// Before processing any webhook event, attempt to INSERT this row.
// If the INSERT fails with a unique-constraint violation, the event is a
// duplicate → return 200 immediately without reprocessing.
//
// Design decisions:
//   • payload is Json (JSONB in Postgres) — stores the full raw event body
//     for audit, debugging, and potential event replay.
//   • status transitions: RECEIVED → PROCESSED | IGNORED | FAILED
//   • error column holds the caught exception message when status = FAILED.
//   • No FK to Payment — the event may arrive before the Payment row exists
//     (race condition on first webhook for a new checkout session).

model WebhookEvent {
  id          String             @id @default(cuid())

  // ── Provider + event identity ──────────────────────────────────────────────
  provider    String             // "stripe" | "rapyd" | "grow" | "grow_saas"
  eventId     String             // provider's own event ID:
                                 //   Stripe: evt_... (from stripe-signature header)
                                 //   Rapyd:  event.id from the webhook body
  eventType   String             // e.g. "payment_intent.succeeded",
                                 //       "PAYMENT_COMPLETED" (Rapyd)

  // ── Raw payload ───────────────────────────────────────────────────────────
  payload     Json               // full webhook body; JSONB in Postgres

  // ── Processing state ──────────────────────────────────────────────────────
  processedAt DateTime           @default(now())
  status      WebhookEventStatus @default(RECEIVED)
  error       String?            // caught exception message when status = FAILED

  // ── Composite idempotency key ──────────────────────────────────────────────
  @@unique([provider, eventId])    // duplicate events → INSERT fails → skip processing

  // ── Indexes ────────────────────────────────────────────────────────────────
  @@index([provider])              // "all Stripe events", "all Rapyd events"
  @@index([status])                // "all FAILED events" for admin debugging
  @@index([processedAt])           // chronological queries + retention cleanup
}

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║  Grow migration — Phase 1 foundation (database + security)                  ║
// ║                                                                            ║
// ║  Additive + nullable only. NO runtime path reads these yet, and no feature ║
// ║  flag flips behavior on. Secrets never live inline on owner rows — they    ║
// ║  are referenced by opaque *SecretRef handles into EncryptedSecret, which   ║
// ║  is reachable only through the secret accessor (src/lib/secrets).          ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// ── Secret-handling enums ──────────────────────────────────────────────────────
enum SecretBackend {
  DB_ENVELOPE // ciphertext = self-describing AES-256-GCM envelope; KEK (env) wraps the DEK — Phase 1 default
  KMS         // ciphertext = KMS-wrapped data key; externalRef set
  VAULT       // value held in an external secret manager; ciphertext null, externalRef set
}

enum SecretPurpose {
  GROW_BROKER_API_KEY    // Rail B — broker Grow merchant credential (owner: GrowBrokerMerchant)
  GROW_SAAS_CHARGE_TOKEN // Rail A — SignDeal SaaS billing token      (owner: Subscription)
  GROW_ONBOARDING_LEAD   // Rail B — onboarding lead payload          (owner: GrowOnboardingSession)
  PAYER_BANK_ACCOUNT     // Rail B — payer bank details (DEFERRED; only if Grow reconciliation requires)
  GROW_SAAS_MERCHANT_API_KEY // Rail A — SignDeal's OWN Grow SaaS merchant API key (owner: Platform singleton)
}

enum PaymentMethod {
  APPLE_PAY
  GOOGLE_PAY
  BIT
  CREDIT_CARD
  BANK_TRANSFER
}

enum GrowOnboardingStatus {
  PENDING
  LINK_ISSUED
  COMPLETED
  EXPIRED
  FAILED
  // Phase 2A — callback received & merchant provisioned, but NOT yet activated.
  // Lifecycle position: PENDING → LINK_ISSUED → PENDING_VERIFICATION → COMPLETED.
  // Appended (not inserted) so the DB enum keeps a stable order and the migration
  // stays a plain ADD VALUE. While a session sits here the merchant stays
  // GrowBrokerMerchant.isActive = false; activation is manual
  // (GROW_ONBOARDING_AUTO_ACTIVATE defaults false).
  PENDING_VERIFICATION
}

// ── EncryptedSecret — secret indirection table ─────────────────────────────────
//
// Owner rows hold only opaque *SecretRef handles; the encrypted secret material
// lives here, reachable only through the secret accessor (src/lib/secrets).
// `id` is APPLICATION-generated (a short cuid-like handle) BEFORE encryption, so
// it can be bound into the AES-GCM AAD — hence NO @default(cuid()) on it.
// Migrating to KMS/Vault later is a per-row `backend` swap, not a schema change.
// Crypto-shred = set purgedAt (+ null the ciphertext).
model EncryptedSecret {
  id          String        @id           // app-generated handle (NOT @default) — bound into AAD
  purpose     SecretPurpose
  rail        String        // "A" | "B" — must equal purpose's canonical rail (validated in the accessor)
  ownerType   String        // "GrowBrokerMerchant" | "Subscription" | "GrowOnboardingSession" | "Payment"
  ownerId     String
  ciphertext  Bytes?        // opaque AES-256-GCM envelope (DB_ENVELOPE backend); null for KMS/VAULT
  externalRef String?       // KMS/VAULT key id; null for DB_ENVELOPE
  encVersion  Int           // envelope format/algorithm version
  kekVersion  Int           // which KEK wrapped the DEK
  backend     SecretBackend @default(DB_ENVELOPE)
  fingerprint String?       // optional HMAC (separate pepper) for idempotency; never the value
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  rotatedAt   DateTime?
  expiresAt   DateTime?
  purgedAt    DateTime?

  @@index([ownerType, ownerId])
  @@index([purpose])
  @@index([expiresAt])
  // Single-active invariant is a PARTIAL UNIQUE index:
  //   UNIQUE ("ownerType","ownerId","purpose") WHERE "purgedAt" IS NULL
  // Prisma's schema DSL cannot express a partial (WHERE) unique index, so it is
  // created via raw SQL in the migration (see the migration's migration.sql).
}

// ── GrowBrokerMerchant (Rail B) ────────────────────────────────────────────────
model GrowBrokerMerchant {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  growUserId      String?  // identifier from the onboarding callback (not a secret)
  businessTitle   String?  // broker business title from onboarding callback (data.business_title)
  trackingCode    String?
  packageId       String?
  packageName     String?  // human-readable Grow package name from callback (data.package_name)
  trackingStatus  String?
  apiKeySecretRef String?  // handle → EncryptedSecret (purpose = GROW_BROKER_API_KEY)
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([growUserId])
}

// ── GrowOnboardingSession (Rail B) ─────────────────────────────────────────────
model GrowOnboardingSession {
  id             String               @id @default(cuid())
  // `reference` is a CSPRNG >=128-bit token set by the application (NOT a cuid).
  // It is the public onboarding handle and is explicitly NOT the sole callback-auth
  // mechanism (Grow origin-auth is a Phase 2 dependency). `id` stays the internal cuid PK.
  reference      String               @unique
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  status         GrowOnboardingStatus @default(PENDING)
  businessNumber String?
  phone          String?              // Phase 2A — phone sent to GetLink; secondary callback-correlation key (tracking_code is primary)
  growUserId     String?              // filled on callback
  leadSecretRef  String?              // handle → EncryptedSecret (purpose = GROW_ONBOARDING_LEAD)
  expectedTrackingCode String?        // Phase 2A — tracking_code if echoed by GetLink (doc-inconsistent; may be null); used for correlation
  statusReason   String?              // Phase 2A — last human-readable status (e.g. callback tracking_status.message)
  attemptCount   Int                  @default(0) // Phase 2A — number of inbound callbacks correlated to this session
  expiresAt      DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  callbackEvents GrowOnboardingCallbackEvent[] // Phase 2A back-relation (no SQL column)

  @@index([userId])
  @@index([status])
}

// ── GrowOnboardingCallbackEvent (Rail B, Phase 2A) ─────────────────────────────
//
// Raw-first audit + idempotency log for the inbound Grow onboarding server-update
// ("callback"). One row per received delivery. Confirmed Grow contract:
//   • callback format = application/json
//   • callback URL = fixed / manually configured on Grow's side (NOT sent in GetLink)
//   • NO onboarding status API — this callback (and/or email) is the ONLY status
//     signal; SignDeal status is read from our own DB.
//
// SECURITY: the callback body carries `api_key` (secret) and PII (name/phone).
// `sanitizedPayload` stores the body AFTER secret-redaction (sanitize-metadata);
// the real api_key is sealed into EncryptedSecret (purpose GROW_BROKER_API_KEY),
// NEVER inline here. Ingestion is unauthenticated/unsigned until Grow confirms
// origin auth, so it moves a session to PENDING_VERIFICATION (merchant isActive
// stays false) — never directly ACTIVE.
//
// NOTE: no runtime path reads/writes this yet (Phase 2A contract — schema only).
model GrowOnboardingCallbackEvent {
  id               String                 @id @default(cuid())
  receivedAt       DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  sessionId        String?                // nullable — correlation may fail (uncorrelated callbacks are still stored)
  session          GrowOnboardingSession? @relation(fields: [sessionId], references: [id])
  sourceIp         String?                // best-effort; proxy / forwarded-header handling is OUT of Phase 2A scope
  httpMethod       String
  contentType      String?                // expected "application/json"
  contentTypeValid Boolean                @default(false)
  sanitizedPayload String                 // body AFTER secret-redaction; NO plaintext api_key here (sealed in EncryptedSecret)
  parsedOk         Boolean                @default(false)
  dedupKey         String                 @unique // hash of stable identity (tracking_code + tracking_status.id) — NOT of the secret
  outcome          String                 @default("stored") // stored | correlated | applied | duplicate | uncorrelated | rejected

  @@index([sessionId])
  @@index([receivedAt])
}
